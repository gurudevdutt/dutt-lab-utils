# Pitt AI Connect (Portkey). Get key(s) from Pitt AI Connect / Portkey portal.
# Copy to .env and fill in: cp .env.example .env
#
# Single key (used for all models if no per-provider keys are set):
PITTAI_API_KEY=
#
# Optional: one key per provider for separate billing. The client picks the key
# from the model string (Anthropic vs Google Vertex vs Azure/OpenAI).
# PITTAI_API_KEY_ANTHROPIC=
# PITTAI_API_KEY_GOOGLE=
# PITTAI_API_KEY_OPENAI=
#
# ElevenLabs TTS (optional). Falls back to gTTS if not set.
ELEVENLABS_API_KEY=
